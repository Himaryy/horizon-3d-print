generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth ─────────────────────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  role          String   @default("user")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions     Session[]
  accounts     Account[]
  addresses    UserAddress[]
  orders       Order[]
  reviews      Review[]
  chatSessions ChatSession[]
  customOrders CustomOrderRequest[]
  cart         Cart?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

// ─── Products ────────────────────────────────────────────────────────────────

enum ProductCategory {
  READY_MADE
  CUSTOM_BASE
}

model Product {
  id           String          @id @default(cuid())
  slug         String          @unique
  name         String
  desc         String
  price        Int
  stock        Int             @default(0)
  category     ProductCategory
  isPublished  Boolean         @default(false) @map("is_published")
  isFeatured   Boolean         @default(false) @map("is_featured")
  modelUrl     String?         @map("model_url")
  videoUrl     String?         @map("video_url")
  tokopediaUrl String?         @map("tokopedia_url")
  shopeeUrl    String?         @map("shopee_url")
  deletedAt    DateTime?       @map("deleted_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  images     ProductImage[]
  variants   ProductVariant[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]

  @@map("product")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  alt       String
  order     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_image")
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  color       String?
  size        String?
  priceAdjust Int      @default(0) @map("price_adjust")
  stock       Int      @default(0)
  sku         String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variant")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  PRINTING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderSource {
  WEBSITE
  TOKOPEDIA
  SHOPEE
}

model Order {
  id               String      @id @default(cuid())
  invoiceNumber    String      @unique @map("invoice_number")
  source           OrderSource @default(WEBSITE) @map("source")
  externalOrderId  String?     @map("external_order_id")
  userId           String?     @map("user_id")
  customerName     String?     @map("customer_name")
  customerEmail    String?     @map("customer_email")
  status           OrderStatus @default(PENDING_PAYMENT)
  subtotal         Int
  shippingCost     Int         @default(0) @map("shipping_cost")
  discountAmount   Int         @default(0) @map("discount_amount")
  total            Int
  couponCode       String?     @map("coupon_code")
  xenditInvoiceId  String?     @unique @map("xendit_invoice_id")
  xenditPaymentUrl String?     @map("xendit_payment_url")
  paidAt           DateTime?   @map("paid_at")
  shippingAddress  Json        @map("shipping_address")
  trackingNumber   String?     @map("tracking_number")
  trackingUrl      String?     @map("tracking_url")
  courier          String?
  notes            String?
  adminNotes       String?     @map("admin_notes")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("order")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String   @map("order_id")
  productId       String   @map("product_id")
  variantId       String?  @map("variant_id")
  productSnapshot Json     @map("product_snapshot")
  qty             Int
  unitPrice       Int      @map("unit_price")
  total           Int
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_item")
}

// ─── Custom Orders ───────────────────────────────────────────────────────────

enum CustomOrderStatus {
  NEW
  UNDER_REVIEW
  QUOTED
  ACCEPTED
  IN_PRODUCTION
  COMPLETED
  REJECTED
  CANCELLED
}

model CustomOrderRequest {
  id          String            @id @default(cuid())
  userId      String?           @map("user_id")
  guestEmail  String?           @map("guest_email")
  guestName   String?           @map("guest_name")
  description String
  refImages   String[]          @map("ref_images")
  size        String?
  colorNote   String?           @map("color_note")
  budgetMin   Int?              @map("budget_min")
  budgetMax   Int?              @map("budget_max")
  status      CustomOrderStatus @default(NEW)
  quotedPrice Int?              @map("quoted_price")
  adminNotes  String?           @map("admin_notes")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("custom_order_request")
}

// ─── Cart ────────────────────────────────────────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  userId     String?  @unique @map("user_id")
  sessionKey String?  @unique @map("session_key")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("cart")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  variantId String?  @map("variant_id")
  qty       Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@map("cart_item")
}

// ─── Chatbot ─────────────────────────────────────────────────────────────────

enum ChatRole {
  USER
  ASSISTANT
}

model ChatSession {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  sessionKey String   @unique @map("session_key")
  escalated  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User?         @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@map("chat_session")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  role      ChatRole
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_message")
}

// ─── Supporting ──────────────────────────────────────────────────────────────

model UserAddress {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  label     String
  isDefault Boolean  @default(false) @map("is_default")
  name      String
  phone     String
  street    String
  city      String
  province  String
  postal    String
  country   String   @default("Indonesia")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_address")
}

model Review {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  userId    String   @map("user_id")
  orderId   String   @map("order_id")
  rating    Int
  comment   String?
  images    String[]
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("review")
}

enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  type      CouponType
  value     Int
  minOrder  Int        @default(0) @map("min_order")
  maxUses   Int?       @map("max_uses")
  usedCount Int        @default(0) @map("used_count")
  expiresAt DateTime?  @map("expires_at")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("coupon")
}
